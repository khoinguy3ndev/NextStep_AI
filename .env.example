# Server Configuration
PORT=3003
APP_NAME="AI Job Matching Server"
DEBUG=True

# Database Configuration
DB_USERNAME=postgres.<your-project-ref>
DB_PASSWORD=<your_supabase_password>
DB_HOST=aws-1-ap-northeast-1.pooler.supabase.com
DB_PORT=6543
DB_NAME=postgres

# Connection URL
DATABASE_URL=postgresql://postgres.<your-project-ref>:<your_supabase_password>@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres?sslmode=require

# Security & JWT
JWT_ACCESS_SECRET=replace_me_access_secret
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_SECRET=replace_me_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d

# AI API configuration
GEMINI_API_KEY=replace_with_your_gemini_api_key
